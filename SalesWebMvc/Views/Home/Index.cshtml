@{
    ViewData["Title"] = "Home";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">System Dashboard</h1>
        <p class="text-muted">Overview of system entities</p>
    </div>
    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <i class="bi bi-person-badge fs-1 mb-3 text-primary"></i>
                <h5 class="fw-bold">Sellers</h5>
                <p class="text-muted">Registration and management of sellers.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <i class="bi bi-cash-stack fs-1 mb-3 text-success"></i>
                <h5 class="fw-bold">Sales</h5>
                <p class="text-muted">Recording and tracking of sales.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <i class="bi bi-building fs-1 mb-3 text-warning"></i>
                <h5 class="fw-bold">Departments</h5>
                <p class="text-muted">Organization of company departments.</p>
            </div>
        </div>
    </div>
</div>