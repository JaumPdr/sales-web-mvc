@{
    ViewData["Title"] = "About";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold mt-2">About the System</h1>
        <p class="text-muted fs-5">A modern and responsive application for sales management</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow border-0 p-4" style="border-radius: 16px;">
                <div class="card-body">

                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-laptop fs-3 text-primary me-2"></i>
                        <h3 class="fw-bold mb-0">Sales Web MVC</h3>
                    </div>

                    <p class="text-secondary fs-6" style="line-height: 1.7;">
                        This system was developed using ASP.NET Core MVC and C#, aiming to manage
                        sellers, sales, and departments in a simple, fast, and highly efficient way.
                    </p>

                    <hr class="my-4 text-muted opacity-25" />

                    <div class="row g-4">

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <i class="bi bi-stars text-warning me-2"></i>Key Features
                            </h5>
                            <ul class="list-unstyled text-secondary">
                                <li class="mb-2 d-flex align-items-center">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <span>Sellers management</span>
                                </li>
                                <li class="mb-2 d-flex align-items-center">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <span>Sales control with date filters</span>
                                </li>
                                <li class="d-flex align-items-center">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <span>Department organization</span>
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <i class="bi bi-code-square text-info me-2"></i>Technologies Used
                            </h5>
                            <div class="bg-light p-3 rounded-3">
                                <ul class="list-unstyled text-secondary mb-0">
                                    <li class="mb-2 d-flex align-items-center">
                                        <i class="bi bi-dot fs-4 text-secondary"></i>ASP.NET Core MVC
                                    </li>
                                    <li class="mb-2 d-flex align-items-center">
                                        <i class="bi bi-dot fs-4 text-secondary"></i>Entity Framework Core
                                    </li>
                                    <li class="d-flex align-items-center">
                                        <i class="bi bi-dot fs-4 text-secondary"></i>Bootstrap 5
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 text-muted opacity-25" />

                    <div class="text-center">
                        <span class="badge bg-light text-secondary p-2 px-3" style="border-radius: 10px;">
                            <i class="bi bi-info-circle me-1"></i> Developed for study and practice purposes
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>